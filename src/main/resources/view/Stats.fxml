<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextField?>
<VBox spacing="20" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="controller.StatsController">

    <Label text="Stats" styleClass="title"/>

    <TextField fx:id="winsField" promptText="Wins"/>
    <TextField fx:id="lossesField" promptText="Losses"/>
    <TextField fx:id="killsField" promptText="Kills"/>

    <Button text="Save" onAction="#handleSave"/>

    <Label fx:id="statusLabel"/>

</VBox>