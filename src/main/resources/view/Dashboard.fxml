<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="24" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.javafxui.controller.DashboardController"
      styleClass="root-pane">

    <Label text="Player Stats Tracker" styleClass="app-title"/>
    <Label fx:id="welcomeLabel" text="Welcome" styleClass="subtitle"/>

    <HBox spacing="22" alignment="CENTER">
        <VBox alignment="CENTER" styleClass="stat-card">
            <Label text="🎮 Total Games" styleClass="card-title"/>
            <Label fx:id="totalGamesLabel" text="0" styleClass="card-value"/>
        </VBox>

        <VBox alignment="CENTER" styleClass="stat-card">
            <Label text="🎯 Total Kills" styleClass="card-title"/>
            <Label fx:id="totalKillsLabel" text="0" styleClass="card-value"/>
        </VBox>

        <VBox alignment="CENTER" styleClass="stat-card">
            <Label text="📈 Average Score" styleClass="card-title"/>
            <Label fx:id="averageScoreLabel" text="0" styleClass="card-value"/>
        </VBox>
    </HBox>

    <HBox spacing="22" alignment="CENTER">

        <VBox spacing="12" alignment="CENTER" styleClass="panel">
            <Label text="Your Games" styleClass="section-title"/>
            <ListView fx:id="gamesListView" prefWidth="340" prefHeight="210"/>
            <Label text="Click a game to view details." styleClass="hint-label"/>
        </VBox>

        <VBox spacing="12" alignment="CENTER" styleClass="panel">
            <Label text="Game Details" styleClass="section-title"/>

            <Label fx:id="selectedGameLabel" text="No game selected" styleClass="detail-title"/>

            <GridPane hgap="18" vgap="10" alignment="CENTER">
                <Label text="Kills:" styleClass="detail-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                <Label fx:id="selectedKillsLabel" text="0" styleClass="detail-value" GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                <Label text="Deaths:" styleClass="detail-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                <Label fx:id="selectedDeathsLabel" text="0" styleClass="detail-value" GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                <Label text="Assists:" styleClass="detail-label" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                <Label fx:id="selectedAssistsLabel" text="0" styleClass="detail-value" GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                <Label text="Score:" styleClass="detail-label" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                <Label fx:id="selectedScoreLabel" text="0" styleClass="detail-value" GridPane.rowIndex="3" GridPane.columnIndex="1"/>

                <Label text="K/D Ratio:" styleClass="detail-label" GridPane.rowIndex="4" GridPane.columnIndex="0"/>
                <Label fx:id="selectedKdLabel" text="0.00" styleClass="detail-value" GridPane.rowIndex="4" GridPane.columnIndex="1"/>
            </GridPane>

            <TextField fx:id="editGameNameField" promptText="New game name" maxWidth="260"/>

            <HBox spacing="12" alignment="CENTER">
                <Button text="Edit Game Name" onAction="#editSelectedGame"/>
                <Button text="Delete Selected Game" onAction="#deleteSelectedGame" styleClass="danger-button"/>
            </HBox>
        </VBox>

    </HBox>

    <HBox spacing="16" alignment="CENTER">
        <Button text="Add Game" onAction="#goToAddGame"/>
        <Button text="Add Stats" onAction="#goToStats"/>
        <Button text="View Report" onAction="#goToReport"/>
        <Button text="Logout" onAction="#logout"/>
    </HBox>

</VBox>