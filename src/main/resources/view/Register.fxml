<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="18" alignment="CENTER"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="org.example.javafxui.controller.RegisterController"
      styleClass="root-pane">

    <Label text="Create Account" styleClass="title"/>

    <TextField fx:id="usernameField" promptText="Username" maxWidth="350"/>
    <TextField fx:id="emailField" promptText="Email" maxWidth="350"/>
    <PasswordField fx:id="passwordField" promptText="Password" maxWidth="350"/>
    <PasswordField fx:id="confirmPasswordField" promptText="Confirm Password" maxWidth="350"/>

    <HBox spacing="12" alignment="CENTER">
        <Button text="Register" onAction="#handleRegister"/>
        <Button text="Back to Login" onAction="#goToLogin"/>
    </HBox>

    <Label fx:id="messageLabel"/>

</VBox>